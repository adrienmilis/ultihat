<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">
        <record id="model_x_club" model="ir.model">
            <field name="model">x_club</field>
            <field name="name">Club</field>
        </record>
        <!-- x_name -->
        <record id="x_club_field_x_name" model="ir.model.fields">
            <field name="name">x_name</field>
            <field name="field_description">Name</field>
            <field name="ttype">char</field>
            <field name="model_id" ref="model_x_club"/>
            <field name="required">True</field>
        </record>
        <!-- x_member_ids -->
        <record id="x_club_field_x_member_ids" model="ir.model.fields">
            <field name="name">x_member_ids</field>
            <field name="field_description">Members</field>
            <field name="ttype">one2many</field>
            <field name="relation">res.partner</field>
            <field name="inverse_name">x_club_id</field>
            <field name="model_id" ref="model_x_club"/>
        </record>
    </data>
</odoo>