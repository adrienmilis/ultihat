<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">
        <record id="model_x_team" model="ir.model">
            <field name="model">x_team</field>
            <field name="name">team</field>
        </record>
        <!-- x_name -->
        <record id="x_team_field_x_name" model="ir.model.fields">
            <field name="name">x_name</field>
            <field name="field_description">Name</field>
            <field name="ttype">char</field>
            <field name="model_id" ref="model_x_team"/>
            <field name="required">True</field>
        </record>
        <!-- x_partner_ids -->
        <record id="x_team_field_x_partner_ids" model="ir.model.fields">
            <field name="name">x_partner_ids</field>
            <field name="field_description">Players</field>
            <field name="ttype">one2many</field>
            <field name="relation">res.partner</field>
            <field name="inverse_name">x_team_id</field>
            <field name="model_id" ref="model_x_team"/>
        </record>
        <!-- x_maker_id -->
        <record id="x_team_field_x_maker_id" model="ir.model.fields">
            <field name="name">x_maker_id</field>
            <field name="field_description">Maker</field>
            <field name="ttype">many2one</field>
            <field name="relation">x_team_maker</field>
            <field name="model_id" ref="ultihat.model_x_team"/>
        </record>
        <!-- avg level -->
        <!-- females ratio -->
        <!-- handlers ratio -->
    </data>
</odoo>