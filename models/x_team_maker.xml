<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="model_x_team_maker" model="ir.model">
        <field name="name">Team Maker</field>
        <field name="model">x_team_maker</field>
    </record>
    <!-- x_name -->
    <record id="x_team_maker_field_x_name" model="ir.model.fields">
        <field name="name">x_name</field>
        <field name="field_description">Name</field>
        <field name="ttype">char</field>
        <field name="model_id" ref="model_x_team_maker"/>
        <field name="required">True</field>
    </record>
    <!-- x_teams_description -->
    <record id="x_team_maker_field_x_teams_description" model="ir.model.fields">
        <field name="name">x_teams_description</field>
        <field name="field_description">Teams Description</field>
        <field name="ttype">text</field>
        <field name="model_id" ref="model_x_team_maker"/>
    </record>
</odoo>