<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="x_club_action" model="ir.actions.act_window">
        <field name="name">Clubs</field>
        <field name="res_model">x.club</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="x_club_menu"
              name="Clubs"
              action="x_club_action"
              parent="contacts.menu_contacts"
              sequence="10"/>

    <record id="x_club_view_list" model="ir.ui.view">
        <field name="name">x.club.view.list</field>
        <field name="model">x.club</field>
        <field name="arch" type="xml">
            <list>
                <field name="x_name"/>
            </list>
        </field>
    </record>

    <record id="x_club_view_form" model="ir.ui.view">
        <field name="name">x.club.view.form</field>
        <field name="model">x.club</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="x_name"/>
                    </group>
                    <notebook>
                        <page string="Members">
                            <field name="x_member_ids"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>